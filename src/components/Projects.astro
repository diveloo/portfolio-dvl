<section id="projects"class="projects-section">
    <div class="projects-content">
        <h2 class="projects-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="url(#gradient-projects)" class="icon icon-tabler icons-tabler-filled icon-tabler-layout-grid">
                <defs>
                    <linearGradient id="gradient-projects" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="var(--accent-blue)" />
                        <stop offset="100%" stop-color="var(--accent-purple)" />
                    </linearGradient>
                </defs>
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 3a2 2 0 0 1 2 2v4a2 2 0 0 1 -2 2h-4a2 2 0 0 1 -2 -2v-4a2 2 0 0 1 2 -2z" /><path d="M19 3a2 2 0 0 1 2 2v4a2 2 0 0 1 -2 2h-4a2 2 0 0 1 -2 -2v-4a2 2 0 0 1 2 -2z" /><path d="M9 13a2 2 0 0 1 2 2v4a2 2 0 0 1 -2 2h-4a2 2 0 0 1 -2 -2v-4a2 2 0 0 1 2 -2z" />
                <path d="M19 13a2 2 0 0 1 2 2v4a2 2 0 0 1 -2 2h-4a2 2 0 0 1 -2 -2v-4a2 2 0 0 1 2 -2z" />
            </svg>
            <span>Mis Proyectos</span>
        </h2>

        <ul class="projects-list">
            <li class="project-card">
                <div class="project-image-container">
                    <img src="/huelgates.png " alt="Imagen del proyecto Huelgates" class="project-image">
                </div>
                <div class="project-info">
                    <h3>Huelgates</h3>
                    <p class="project-description">
                        Aplicación/Juego Educativo tipo Escape Room para el colegio Huelgas Reales de Valladolid
                        en colaboración con 3 compañeros de universidad.
                    </p>
                    <ul class="project-tech">
                        <li><span>Kotlin</span></li>
                        <li><span>Firebase</span></li>
                    </ul>
                    
                    <footer class="project-links">
                        <a href="https://github.com/diveloo/app-huelgates" class="btn-github" target="_blank" rel="noopener noreferrer">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-code">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M7 8l-4 4l4 4" />
                                <path d="M17 8l4 4l-4 4" />
                                <path d="M14 4l-4 16" /></svg>
                            Ver código</a>
                        <a href="https://www.linkedin.com/in/divelo/details/projects/" class="btn-linkedin" target="_blank" rel="noopener noreferrer">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-info-circle">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" />
                                <path d="M12 9h.01" />
                                <path d="M11 12h1v4h1" />
                            </svg>
                            Saber más
                        </a>
                    </footer>
                </div>
            </li>
        </ul>
    </div>
</section>


<style>
    .projects-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 80px 10%;
        max-width: 1400px;
        margin: 0 auto;
    }

    .projects-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 40px;
    }

    .projects-title svg{
        width: 32px;
        height: 32px;
    }

    .projects-list {
        display: grid;
        /* La magia está en usar auto-fill en lugar de auto-fit */
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 30px;
        padding: 0;
        list-style: none;
    }

    .project-card {
        background-color: rgba(255, 255, 255, 0.03); /* Un fondo apenas visible */
        border: 1px solid rgba(255, 255, 255, 0.1); /* Borde sutil */
        border-radius: 12px; /* Esquinas redondeadas */
        overflow: hidden; /* Evita que la imagen se salga de las esquinas redondeadas */
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;

        &:hover {
            transform: translateY(-5px); /* La tarjeta "flota" hacia arriba */
            border-color: rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
    }

    /* Zona de la imagen */
    .project-image-container {
        width: 100%;
        aspect-ratio: 16 / 9; /* Mantiene una proporción de 16:9 */
        background-color: #1f2937; /* Color de fondo mientras no hay imagen real */
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        overflow: hidden;
    }

    .project-image {
        width: 100%;
        height: 100%;
        object-fit: cover; 
        object-position: center top; 
        transition: transform 0.4s ease;
    }

    .project-card:hover .project-img {
        transform: scale(1.05); 
    }

    /* Zona de la información debajo de la imagen */
    .project-info {
        padding: 25px;
        display: flex;
        flex-direction: column;
        flex-grow: 1; /* Hace que esta zona ocupe todo el alto disponible */
        gap: 15px;
    }

    .project-info h3 {
        font-size: 1.5rem;
        color: white;
    }

    .project-description {
        color: var(--text-muted);
        line-height: 1.6;
        font-size: 1rem;
    }

    /* TECNOLOGÍAS (Las píldoras) */
    .project-tech {
        display: flex;
        flex-wrap: wrap; /* Si hay muchas tecnologías, saltan a la línea de abajo */
        gap: 10px;
        padding: 0;
        list-style: none;
    }

    .project-tech span {
        background-color: rgba(37, 99, 235, 0.15); /* Fondo azul muy transparente */
        color: #60a5fa; /* Texto azul claro */
        padding: 6px 14px;
        border-radius: 20px; /* Esto hace la forma de píldora */
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    /* ENLACES Y BOTONES DEL FOOTER */
    .project-links {
        margin-top: auto; /* IMPORTANTE: Esto empuja los botones hacia el final de la tarjeta */
        padding-top: 20px;
    }

    .btn-github {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background-color: transparent;
        border: 1px solid var(--text-muted);
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s ease;


        &:hover {
            border-color: white;
            background-color: rgba(255, 255, 255, 0.1);
        }

        svg {
            width: 20px;
            margin-right: 8px;
        }
    }

    .btn-linkedin {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background-color: transparent;
        border: 1px solid var(--text-muted);
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s ease;

        &:hover {
            border-color: white;
            background-color: rgba(255, 255, 255, 0.1);
        }

        svg {
            width: 20px;
            margin-right: 8px;
        }
    }

    /* RESPONSIVE: En móviles reducimos un poco el padding general */
    @media (max-width: 768px) {
        .projects-section {
            padding: 60px 5%;
        }
    }

</style>