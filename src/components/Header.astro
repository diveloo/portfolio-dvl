<style>

    @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap');


    .header-body{
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: "Lexend", sans-serif;
        color: white;
        background-color: var(--background-color);
        padding: 40px;

        border-bottom: 0.1rem solid rgba(255, 255, 255, 0.1);
    }

    .brand{
        display:flex;
        align-items: center;
        gap: 25px;

        h1 {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        a {
            color: white;
            text-decoration: none;
        }

        &:hover {
            cursor: pointer;
            filter: drop-shadow(10px 10px 5px rgba(0, 0, 0, 0.3));
        }
    }

    .icon-box{
        background-image: linear-gradient(135deg, #2563eb, #9115df);
        padding: 6px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .brand h1 {
        
    }

    .hamburger-btn {
        display: none;
        background: none;
        border: none;
        color: white;
        cursor: pointer;
    }

    .nav-container {
        display: flex;
        align-items: center;
        gap: 80px;
    }

    .menu-header {
        display: flex;
        gap: 50px;
    }

    .menu-header a {
        background-image: linear-gradient(
            to right, 
            #cbd5e1 0%, 
            #cbd5e1 33%, /* Parte izquierda: Gris normal */
            #2563eb 66%, /* Parte derecha: Inicio gradiente azul */
            #9115df 100% /* Parte derecha: Fin gradiente azul */
        );
        background-size: 300% 100%;
        background-position: 0% 0%;

        --webkit-background-clip: text;
        background-clip: text;
        color: transparent;

        text-decoration: none;
        font-weight: 700;
        font-size: 1.5rem;
        transition: background-position 0.3s ease;
    }

    .menu-header a:hover {
        background-position: 100% 0%;
    }

    .social-header {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .social-header a {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-color); /* Color grisáceo por defecto */
        background-color: rgba(255, 255, 255, 0.05); /* Fondo semitransparente */
        padding: 10px;
        border-radius: 50%; /* Hace que el fondo sea un círculo */
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .social-header a:hover {
        color: white; /* El icono se vuelve blanco brillante */
        background-color: rgba(255, 255, 255, 0.1);
        border-color: var(--accent-purple); /* El borde se pinta de tu azul */
        transform: translateY(-1px); /* El botón "salta" un poquito hacia arriba */
        box-shadow: 0 8px 10px rgba(37, 99, 235, 0.3); /* Sombra azul brillante */
    }

    @media (max-width: 900px){
        .hamburger-btn {
            display: block;
        }

        .nav-container {
            position: absolute; /* Lo sacamos del flujo normal */
            top: 100px; /* Lo ponemos justo debajo del header (ajusta esto si queda muy pegado) */
            left: 0;
            width: 100%;
            background-color: var(--background-color);
            flex-direction: column; /* Ponemos los elementos en columna */
            padding: 40px 0;
            gap: 30px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 50;
            
            /* Ocultamos este menú por defecto */
            display: flex;
            visibility: hidden;
            opacity: 0;
            transform: translateY(-10px);
            transition: opacity 0.4s ease-in-out;
        }

        .nav-container.is-open {
            visibility: visible;
            opacity: 1;
            transform: translateY(0);
        }

        .menu-header {
            flex-direction: column;
            align-items: center;
            gap: 25px;
        }
    }
</style>

<script>

    const menuToggle = document.getElementById('menu-toggle');
    const navContainer = document.getElementById('nav-container');

    menuToggle?.addEventListener('click', () => {
        navContainer?.classList.toggle('is-open');
    })
</script>